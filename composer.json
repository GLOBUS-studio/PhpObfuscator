{
    "name": "globus-studio/php-obfuscator",
    "description": "A token-based PHP source code obfuscator with full support for PHP 8.1 through 8.5.",
    "type": "library",
    "version": "1.0.0",
    "keywords": ["obfuscator", "obfuscate", "php", "source-code", "protection", "minify", "tokenizer"],
    "license": "MIT",
    "homepage": "https://github.com/GLOBUS-studio/PhpObfuscator",
    "support": {
        "issues": "https://github.com/GLOBUS-studio/PhpObfuscator/issues",
        "source": "https://github.com/GLOBUS-studio/PhpObfuscator"
    },
    "require": {
        "php": "^8.1",
        "ext-tokenizer": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "GLOBUSstudio\\PhpObfuscator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GLOBUSstudio\\PhpObfuscator\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/php-obfuscate"
    ],
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text --coverage-html=build/coverage"
    },
    "config": {
        "sort-packages": true
    }
}
